---
import { profile } from '@/data/profile'
import '@/styles/globals.css'

export interface Props {
  title?: string
  description?: string
  type?: 'website' | 'article' | 'profile'
  publishedTime?: string
  modifiedTime?: string
  schema?: Record<string, any> | Record<string, any>[]
}

const {
  title = profile.seo.title,
  description = profile.seo.description,
  type = 'website',
  publishedTime,
  modifiedTime,
  schema,
} = Astro.props

const siteUrl = profile.seo.siteUrl.replace(/\/$/, '')
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString()
const ogImage = new URL(`/og.png?v=${profile.share.image.version}`, siteUrl).toString()
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : []
const themeStyle = {
  '--color-ink': profile.theme.ink,
  '--color-paper': profile.theme.paper,
  '--color-paper-2': profile.theme.paper2,
  '--color-surface': profile.theme.surface,
  '--color-line': profile.theme.line,
  '--color-muted': profile.theme.muted,
  '--color-accent': profile.theme.accent,
  '--color-accent-2': profile.theme.accent2,
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={profile.seo.keywords.join(', ')} />
    <meta name="author" content={profile.name} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title={`${profile.name} updates`} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM context" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(profile.share.image.width)} />
    <meta property="og:image:height" content={String(profile.share.image.height)} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content={profile.theme.paper} />
    <meta name="ai-content" content="allowed" />
    <meta name="gptbot" content="index,follow" />
    <meta name="chatgpt-user" content="index,follow" />
    <meta name="anthropic-ai" content="index,follow" />
    <meta name="perplexitybot" content="index,follow" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {schemas.map(s => <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />)}
  </head>
  <body style={themeStyle}>
    <slot />
  </body>
</html>
