---
import type { ProfileSite } from '@/data/profile'

export interface Props {
  profile: ProfileSite
}

const { profile } = Astro.props
const video = profile.videoAvatar
---

<div
  class="relative h-full w-full"
  data-cycle-media={video ? 'true' : undefined}
>
  <img
    src={profile.avatar.src}
    alt={profile.avatar.alt}
    class="h-full w-full object-cover"
    draggable="false"
  />
  {video && (
    <video
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500 data-[active=true]:opacity-100"
      data-cycle-video
      src={`${video.src}#t=0.1`}
      poster={video.poster}
      aria-label={video.label}
      muted
      loop
      playsinline
      preload="metadata"
      controlslist="nodownload nofullscreen noplaybackrate"
      disablepictureinpicture
      tabindex="-1"
    ></video>
  )}
</div>

<script>
  const shouldReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const playMs = 5000
  const restMs = 3000

  if (!shouldReduceMotion) {
    for (const wrapper of document.querySelectorAll<HTMLElement>('[data-cycle-media]')) {
      const video = wrapper.querySelector<HTMLVideoElement>('[data-cycle-video]')
      if (!video)
        continue

      video.controls = false
      video.muted = true
      video.setAttribute('muted', '')
      video.playsInline = true

      let timer: number | undefined

      const rest = () => {
        video.pause()
        video.dataset.active = 'false'
        timer = window.setTimeout(play, restMs)
      }

      const play = () => {
        video.currentTime = 0
        video.dataset.active = 'true'
        void video.play()
          .then(() => {
            timer = window.setTimeout(rest, playMs)
          })
          .catch(() => {
            video.dataset.active = 'false'
            timer = window.setTimeout(play, restMs)
          })
      }

      const stop = () => {
        if (timer)
          window.clearTimeout(timer)
        video.pause()
        video.dataset.active = 'false'
      }

      const observer = new IntersectionObserver(([entry]) => {
        stop()
        if (entry?.isIntersecting)
          timer = window.setTimeout(play, restMs)
      })

      observer.observe(wrapper)

      document.addEventListener('visibilitychange', () => {
        if (document.hidden)
          stop()
        else
          timer = window.setTimeout(play, restMs)
      })
    }
  }
</script>
