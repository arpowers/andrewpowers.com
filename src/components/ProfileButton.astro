---
import type { SocialLink } from '@/data/profile'

export interface Props {
  link: SocialLink
  label?: string
  iconOnlyOnMobile?: boolean
  fullWidthOnMobile?: boolean
}

const {
  link,
  label = link.label,
  iconOnlyOnMobile = false,
  fullWidthOnMobile = false,
} = Astro.props
---

<a
  class:list={[
    'inline-flex min-h-11 items-center justify-center gap-2 rounded-full py-2.5 text-sm font-medium transition-colors',
    iconOnlyOnMobile ? 'w-12 px-0 sm:w-auto sm:px-5' : 'px-5',
    fullWidthOnMobile && 'w-full sm:w-auto',
    'focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-4',
    link.primary
      ? 'border border-ink bg-ink text-white shadow-[0_1px_1px_hsl(215deg_35%_12%_/_0.08),0_10px_22px_hsl(245deg_60%_45%_/_0.12)] hover:border-accent hover:bg-accent'
      : 'border border-line bg-surface text-ink shadow-[0_1px_1px_hsl(215deg_35%_32%_/_0.035),0_4px_10px_hsl(215deg_35%_32%_/_0.045)] hover:border-ink',
  ]}
  href={link.href}
  aria-label={label}
>
  {link.logoSrc
    ? <img class="size-5 shrink-0 object-contain" src={link.logoSrc} alt="" aria-hidden="true" />
    : <span class:list={[link.icon, 'size-4 shrink-0']} aria-hidden="true"></span>}
  <span class:list={[iconOnlyOnMobile && 'sr-only sm:not-sr-only']}>{label}</span>
</a>
