---
import type { SocialLink } from '@/data/profile'

export interface Props {
  link: SocialLink
}

const { link } = Astro.props
---

<a
  class:list={[
    'inline-flex min-h-12 items-center gap-2 rounded-full px-5 py-3 text-sm font-medium transition',
    'focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-4',
    link.primary
      ? 'border border-accent bg-accent text-paper shadow-[0_16px_36px_rgba(15,107,95,0.22)] hover:bg-ink hover:border-ink'
      : 'border border-line bg-paper text-ink hover:border-accent hover:text-accent',
  ]}
  href={link.href}
>
  <span class:list={[link.icon, 'size-4 shrink-0']} aria-hidden="true"></span>
  <span>{link.label}</span>
</a>
