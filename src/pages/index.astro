---
import Layout from "@/layouts/LayoutBase.astro";
import ProfileMedia from "@/components/ProfileMedia.astro";
import ProfileButton from "@/components/ProfileButton.astro";
import { getPublishedPosts, normalizeSlug } from "@/utils/posts";
import { profile, type HeroAction, type SocialLink } from "@/data/profile";

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 3);
const socialLinksByKey = new Map(profile.socialLinks.map((link) => [link.key, link]));
const heroActions: Array<HeroAction & { link: SocialLink }> = profile.hero.actions.flatMap((action) => {
  const link = socialLinksByKey.get(action.linkKey);

  return link ? [{ ...action, link }] : [];
});

const personSchema: Record<string, any> = {
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.role.text,
  description: profile.seo.aiAnswer,
  image: new URL(profile.avatar.src, profile.seo.siteUrl).toString(),
  url: profile.seo.siteUrl,
  address: {
    "@type": "PostalAddress",
    addressLocality: profile.location,
  },
  knowsAbout: profile.structuredData.knowsAbout,
  award: profile.seo.proofPoints,
  sameAs: profile.socialLinks
    .map((link) => link.href)
    .filter((href) => href.startsWith("http")),
};

if (profile.structuredData.worksFor) {
  personSchema.worksFor = {
    "@type": profile.structuredData.worksFor.schemaType ?? "Organization",
    name: profile.structuredData.worksFor.name,
    ...(profile.structuredData.worksFor.url ? { url: profile.structuredData.worksFor.url } : {}),
  };
}

if (profile.structuredData.alumniOf?.length) {
  personSchema.alumniOf = profile.structuredData.alumniOf.map((organization) => ({
    "@type": organization.schemaType ?? "Organization",
    name: organization.name,
    ...(organization.url ? { url: organization.url } : {}),
  }));
}

if (profile.structuredData.subjectOf?.length) {
  personSchema.subjectOf = profile.structuredData.subjectOf.map((work) => ({
    "@type": "CreativeWork",
    name: work.name,
    ...(work.url ? { url: work.url } : {}),
    ...(work.publisher
      ? {
          publisher: {
            "@type": work.publisher.schemaType ?? "Organization",
            name: work.publisher.name,
            ...(work.publisher.url ? { url: work.publisher.url } : {}),
          },
        }
      : {}),
  }));
}

const schema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: personSchema,
};
---

<Layout
  title={profile.seo.title}
  description={profile.seo.description}
  type="profile"
  schema={schema}
>
  <main class="min-h-dvh">
    <section
      class="mx-auto grid min-h-dvh w-[min(1120px,calc(100%-40px))] content-center items-center gap-8 py-10 text-center sm:w-[min(1120px,calc(100%-48px))] sm:gap-10 lg:grid-cols-[420px_minmax(0,1fr)] lg:gap-12 lg:py-12 lg:text-left xl:gap-14"
    >
      <div
        class="relative mx-auto w-full max-w-28 sm:max-w-[340px] lg:max-w-[420px]"
      >
        <div
          class="aspect-square overflow-hidden rounded-full bg-paper-2 outline outline-1 outline-line shadow-[inset_0_0_0_8px_rgb(255_255_255_/_0.92),inset_0_0_0_9px_hsl(204deg_42%_68%_/_0.18),0_1px_1px_hsl(215deg_35%_32%_/_0.035),0_3px_6px_hsl(215deg_35%_32%_/_0.035),0_14px_28px_hsl(215deg_35%_32%_/_0.045)] lg:rounded-[2.5rem]"
        >
          <ProfileMedia profile={profile} />
        </div>
        <div
          class="absolute bottom-0 left-1/2 hidden -translate-x-1/2 translate-y-1/2 items-center gap-2 whitespace-nowrap rounded-full bg-surface px-4 py-2 text-sm text-muted shadow-[0_0_0_5px_rgb(255_255_255),0_0_0_6px_hsl(204deg_42%_82%_/_0.8),0_1px_1px_hsl(215deg_35%_32%_/_0.04),0_2px_4px_hsl(215deg_35%_32%_/_0.04),0_10px_18px_hsl(215deg_35%_32%_/_0.06)] lg:inline-flex"
        >
          <span class="i-tabler-map-pin size-4 text-accent" aria-hidden="true"
          ></span>
          {profile.location}
        </div>
      </div>

      <div class="mx-auto w-full max-w-[680px] lg:mx-0">
        <p
          class="mb-4 text-sm md:text-base font-medium leading-[1.35] text-muted"
        >
          <a
            class="transition-colors hover:text-ink"
            href={profile.role.link}
          >
            {profile.role.text}
          </a>
        </p>
        <h1
          class="mb-4 max-w-[700px] text-4xl font-bold leading-[0.98] tracking-[-0.045em] sm:text-6xl lg:text-7xl"
        >
          {profile.name}
        </h1>
        <p
          class="mx-auto mb-8 max-w-[310px] text-pretty text-lg leading-[1.4] text-muted sm:max-w-[640px] sm:text-4xl lg:mx-0 lg:mb-10 lg:text-[1.9rem]"
        >
          {profile.summary}
        </p>
        <nav
          aria-label="Social links"
          class="mx-auto flex w-full max-w-[360px] items-center justify-center gap-3 sm:max-w-none lg:mx-0 lg:justify-start"
        >
          {
            heroActions.map((action) => (
              action.variant === "primary" ? (
                <ProfileButton
                  link={action.link}
                  label={action.label ?? action.link.label}
                />
              ) : (
                <a
                  class="inline-flex size-11 shrink-0 items-center justify-center rounded-full border border-line bg-surface text-ink shadow-[0_1px_1px_hsl(215deg_35%_32%_/_0.035),0_4px_10px_hsl(215deg_35%_32%_/_0.045)] transition-colors hover:border-ink focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-4"
                  href={action.link.href}
                  aria-label={action.label ?? action.link.label}
                >
                  {action.link.logoSrc
                    ? <img class="size-5 shrink-0 object-contain" src={action.link.logoSrc} alt="" aria-hidden="true" />
                    : <span class:list={[action.link.icon, "size-4 shrink-0"]} aria-hidden="true" />}
                </a>
              )
            ))
          }
        </nav>
        <p class="mt-7 text-sm font-medium leading-6 text-muted">
          <a class="underline decoration-line underline-offset-4 transition-colors hover:text-ink" href="/about/">
            About Andrew
          </a>
        </p>
      </div>
    </section>

    {
      latestPosts.length > 0 && (
        <section class="border-t border-line bg-paper-2 py-16">
          <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
            <div class="mb-8 flex items-end justify-between gap-6">
              <div>
                <p class="mb-3 text-[15px] font-medium leading-[1.35] text-muted md:text-base">
                  Latest
                </p>
                <h2 class="text-3xl font-semibold">Notes and updates</h2>
              </div>
              <a
                class="text-sm font-medium transition-colors hover:text-accent"
                href="/blog"
              >
                View all
              </a>
            </div>
            <div class="grid gap-4 md:grid-cols-3">
              {latestPosts.map((post) => (
                <a
                  class="rounded-2xl border border-line bg-paper p-6 transition-colors hover:border-accent"
                  href={`/blog/${normalizeSlug(post.id)}`}
                >
                  <p class="mb-4 text-[15px] font-medium leading-[1.35] text-muted md:text-base">
                    {post.data.publishDate.toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </p>
                  <h3 class="mb-3 text-xl font-semibold leading-tight">
                    {post.data.title}
                  </h3>
                  <p class="text-sm leading-6 text-muted">
                    {post.data.description}
                  </p>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }
  </main>
</Layout>
