---
import Layout from "@/layouts/LayoutBase.astro";
import { profile } from "@/data/profile";

const aboutUrl = new URL("/about", profile.seo.siteUrl).toString();
const personSchema: Record<string, any> = {
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.role.text,
  description: profile.about.shortBio,
  image: new URL(profile.avatar.src, profile.seo.siteUrl).toString(),
  url: profile.seo.siteUrl,
  sameAs: profile.socialLinks
    .map((link) => link.href)
    .filter((href) => href.startsWith("http")),
  knowsAbout: profile.structuredData.knowsAbout,
  award: profile.seo.proofPoints,
  address: {
    "@type": "PostalAddress",
    addressLocality: profile.location,
  },
};

if (profile.structuredData.worksFor) {
  personSchema.worksFor = {
    "@type": profile.structuredData.worksFor.schemaType ?? "Organization",
    name: profile.structuredData.worksFor.name,
    ...(profile.structuredData.worksFor.url ? { url: profile.structuredData.worksFor.url } : {}),
  };
}

if (profile.structuredData.alumniOf?.length) {
  personSchema.alumniOf = profile.structuredData.alumniOf.map((organization) => ({
    "@type": organization.schemaType ?? "Organization",
    name: organization.name,
    ...(organization.url ? { url: organization.url } : {}),
  }));
}

if (profile.structuredData.subjectOf?.length) {
  personSchema.subjectOf = profile.structuredData.subjectOf.map((work) => ({
    "@type": "CreativeWork",
    name: work.name,
    ...(work.url ? { url: work.url } : {}),
    ...(work.publisher
      ? {
          publisher: {
            "@type": work.publisher.schemaType ?? "Organization",
            name: work.publisher.name,
            ...(work.publisher.url ? { url: work.publisher.url } : {}),
          },
        }
      : {}),
  }));
}

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: profile.about.title,
    description: profile.about.description,
    url: aboutUrl,
    mainEntity: personSchema,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: profile.seo.siteUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "About",
        item: aboutUrl,
      },
    ],
  },
];
---

<Layout
  title={`${profile.about.title} - ${profile.name}`}
  description={profile.about.description}
  type="profile"
  schema={schema}
>
  <main class="min-h-dvh bg-paper text-ink">
    <article class="mx-auto grid min-h-dvh w-[min(960px,calc(100%-40px))] content-center py-16 sm:w-[min(960px,calc(100%-56px))]">
      <a
        class="mb-14 inline-flex w-fit items-center gap-2 text-sm font-medium text-muted transition-colors hover:text-ink"
        href="/"
      >
        <span class="i-tabler-arrow-left size-4" aria-hidden="true"></span>
        Home
      </a>

      <header class="mb-14 max-w-[780px]">
        <p class="mb-5 text-base font-medium leading-[1.35] text-muted">
          <a class="transition-colors hover:text-ink" href={profile.role.link}>
            {profile.role.text}
          </a>
        </p>
        <h1 class="mb-6 text-5xl font-bold leading-[0.98] tracking-[-0.045em] sm:text-7xl">
          {profile.name}
        </h1>
        <p class="max-w-[720px] text-pretty text-2xl leading-[1.28] text-muted sm:text-4xl">
          {profile.about.intro}
        </p>
      </header>

      <section aria-label="Proof points" class="mb-16 grid gap-px border-y border-line bg-line sm:grid-cols-4">
        {profile.about.proofPoints.map((point) => (
          <div class="bg-paper py-6 sm:px-6">
            <p class="mb-2 text-4xl font-semibold leading-none tracking-[-0.045em]">
              {point.value}
            </p>
            <p class="text-sm font-medium leading-5 text-muted">
              {point.label}
            </p>
          </div>
        ))}
      </section>

      <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_280px]">
        <section class="max-w-[720px]">
          <h2 class="sr-only">Biography</h2>
          <p class="mb-8 text-xl font-medium leading-8 text-ink">
            {profile.about.shortBio}
          </p>
          <div class="space-y-6 text-lg leading-8 text-muted">
            {profile.about.longBio.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </section>

        <aside class="space-y-10 border-t border-line pt-8 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0">
          <section>
            <h2 class="mb-4 text-base font-semibold leading-6 text-muted">
              Known for
            </h2>
            <ul class="space-y-3 text-base leading-6">
              {profile.structuredData.knowsAbout.slice(0, 6).map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>

          <section>
            <h2 class="mb-4 text-base font-semibold leading-6 text-muted">
              References
            </h2>
            <ul class="space-y-4 text-base leading-6">
              {profile.structuredData.subjectOf?.map((work) => (
                <li>
                  {work.url
                    ? <a class="underline decoration-line underline-offset-4 transition-colors hover:text-accent" href={work.url}>{work.name}</a>
                    : work.name}
                  {work.publisher && <span class="block text-sm text-muted">{work.publisher.name}</span>}
                </li>
              ))}
            </ul>
          </section>
        </aside>
      </div>
    </article>
  </main>
</Layout>
